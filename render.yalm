services:
  - type: web
    plan: free
    name: PbxBot
    env: python
    buildCommand: pip install -r requirements.txt
    startCommand: python3 -m Pbxbot
    autoDeploy: False
    envVars:
    - key: BOT_TOKEN
      sync: false
    - key: API_HASH
      sync: false
    - key: API_ID
      sync: false
    - key: DATABASE_URL
      sync: false
    - key: HANDLERS
      sync: false
    - key: LOGGER_ID
      sync: false
    - key: OWNER_ID
      sync: false
